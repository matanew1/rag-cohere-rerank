{
  "name": "rag-cohere-rerank",
  "version": "1.0.0",
  "description": "NestJS RAG pipeline with Cohere reranking, Chroma vector store, and Mistral generation",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "docker:down": "docker compose down --remove-orphans",
    "docker:clean": "docker compose down --volumes --remove-orphans",
    "docker:rebuild": "docker compose build --no-cache",
    "docker:reset": "npm run docker:clean && npm run docker:rebuild && docker compose up",
    "compare": "ts-node -r tsconfig-paths/register scripts/compare.ts",
    "generate:pdf": "ts-node scripts/generate-pdf.ts"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^11.4.2",
    "@xenova/transformers": "^2.17.2",
    "chromadb": "^1.9.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cohere-ai": "^7.14.0",
    "dotenv": "^16.4.5",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "pdfkit": "^0.18.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
